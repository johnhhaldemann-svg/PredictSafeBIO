# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only. NEVER expose this key client-side or commit it to source control.
SUPABASE_SERVICE_ROLE_KEY=

DATABASE_URL=

# ── AI / LLM ──────────────────────────────────────────────────────────────────
# Used by draft-assist /api/ai/draft — get key at console.anthropic.com
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Platform Environment ──────────────────────────────────────────────────────
# Controls which environment tier this deployment runs as.
# Allowed values: development | staging | demo | production | sandbox | archive
# This value is used to tag all new records with an environment column and to
# enforce data separation rules. Production must never contain demo/test data.
APP_ENV=development

# The canonical URL for this deployment (used in emails, redirects, og tags).
# Examples:
#   development:  http://localhost:3000
#   staging:      https://staging.predictsafe-bio.vercel.app
#   production:   https://predictsafe-bio.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

NEXT_PUBLIC_SITE_URL=https://predictsafe-bio.vercel.app

# ── Storage ───────────────────────────────────────────────────────────────────
# Supabase Storage bucket for compliance documents, SOPs, appendices, forms, and
# generated files. Create this bucket in Supabase Storage before enabling uploads.
# Path convention: {organization_id}/{document_id}/{filename}
STORAGE_BUCKET_DOCUMENTS=biotech-documents

# ── Feature Flags ─────────────────────────────────────────────────────────────
# Enable the LLM draft-assist layer (deterministic engine must pass first).
# Keep "false" in production until all review-workflow tests are green.
NEXT_PUBLIC_ENABLE_LLM_DRAFT_ASSIST=false

# Enable the Risk Cells / AMAYA precursor intelligence module.
# Set to "true" only when risk_cells table is populated and UI is wired.
NEXT_PUBLIC_FEATURE_RISK_CELLS=false

# Demo mode: locks sample data and prevents accidental production writes.
# Set to "true" for sales walkthroughs and investor demos.
# When active, write operations to production tables are blocked server-side.
NEXT_PUBLIC_FEATURE_DEMO_MODE=false

# ── Audit Log ────────────────────────────────────────────────────────────────
# Forces all create/update/delete actions to write an audit_events row.
# Must be "true" in staging and production. Leave blank (defaults true) in dev.
AUDIT_LOG_ENABLED=true

# ── Auth Guards ───────────────────────────────────────────────────────────────
# Set to "true" ONLY while email confirmation is intentionally disabled during
# local smoke testing. Remove or set to "false" before any public-facing demo,
# pilot, or production deployment. A visible warning banner appears on the
# signup page as a reminder to re-harden auth.
NEXT_PUBLIC_EMAIL_CONFIRMATION_DISABLED=

# Set to "true" to enforce invite-only signup. When active, new users must have
# a valid pending invite matching their email to complete onboarding.
NEXT_PUBLIC_INVITE_ONLY=

# ── Admin ────────────────────────────────────────────────────────────────────
# Secret key to access the platform operations page at /admin/platform?key=<value>.
# Set to a strong random string. Never expose this value publicly.
# Leave blank to disable the platform ops page entirely.
PLATFORM_ADMIN_KEY=

# ── Stripe (Phase 4 — Billing & Subscriptions) ───────────────────────────────
# Card data is NEVER stored in our database. Stripe handles all PCI compliance.
#
# 1. Create a Stripe account at https://dashboard.stripe.com
# 2. Under Developers → API keys, copy your keys:
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
#
# 3. Add a webhook in Stripe Dashboard → Developers → Webhooks:
#    URL: https://your-domain.com/api/stripe/webhook
#    Events: checkout.session.completed, invoice.payment_succeeded,
#            invoice.payment_failed, customer.subscription.updated,
#            customer.subscription.deleted
STRIPE_WEBHOOK_SECRET=whsec_...
#
# 4. In Admin → Billing → Plans, paste Stripe Price IDs (price_xxx) for
#    Basic and Pro tiers. Free tier needs no Price ID.
#
# Payments activate automatically once all 3 keys are present.
