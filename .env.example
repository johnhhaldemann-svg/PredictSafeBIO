NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=
OPENAI_API_KEY=

# Set to "true" ONLY while email confirmation is intentionally disabled during local smoke testing.
# Remove or set to "false" before any public-facing demo, pilot, or production deployment.
# When set, a visible warning banner appears on the signup page as a reminder to re-harden auth.
NEXT_PUBLIC_EMAIL_CONFIRMATION_DISABLED=

# Set to "true" to enforce invite-only signup.
# When active, new users must have a valid pending invite matching their email
# to complete onboarding. Leave blank or "false" for open signup.
NEXT_PUBLIC_INVITE_ONLY=

# Required for the owner invite flow (sends Supabase Auth invite emails).
# Never expose this key client-side.
NEXT_PUBLIC_SITE_URL=https://predictsafe-bio.vercel.app
